{
  "_comment": "Claude Code settings for the autoresearch workspace. hcom will install its own hooks on `hcom hooks add`; do not edit the `hooks` block manually. The rules below are loaded automatically.",
  "env": {
    "HCOM": "hcom"
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "python .claude/hooks/hcom_hook.py notify",
            "type": "command"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "command": "python .claude/hooks/hcom_hook.py permission-request",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python .claude/hooks/hcom_hook.py post",
            "timeout": 86400,
            "type": "command"
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "command": "python .claude/hooks/PostToolUse.py",
            "type": "command",
            "timeout": 5000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "python .claude/hooks/hcom_hook.py pre",
            "type": "command"
          }
        ],
        "matcher": "Bash|Task|Write|Edit"
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "command": "python .claude/hooks/PreToolUse.py",
            "type": "command",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "python .claude/hooks/hcom_hook.py sessionend",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "python .claude/hooks/hcom_hook.py sessionstart",
            "type": "command"
          }
        ]
      },
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "command": "python .claude/hooks/activate_caveman.py",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "python .claude/hooks/hcom_hook.py poll",
            "timeout": 86400,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "python .claude/hooks/hcom_hook.py subagent-start",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "python .claude/hooks/hcom_hook.py subagent-stop",
            "timeout": 86400,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python .claude/hooks/hcom_hook.py userpromptsubmit",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(hcom term:*)",
      "Bash(hcom hooks:*)",
      "Bash(uv run python -m tools.artifact_io:*)",
      "Bash(uv run python -m tools.validator:*)",
      "Bash(uv run python -m tools.manifest:*)",
      "Bash(uv run python -m tools.fetch_input:*)",
      "Bash(uv run python -m tools.spec_io:*)",
      "Bash(uv run python -m tools.validate_specs:*)",
      "Bash(hcom send:*)",
      "Bash(uvx hcom send:*)",
      "Bash(hcom start:*)",
      "Bash(uvx hcom start:*)",
      "Bash(hcom help:*)",
      "Bash(uvx hcom help:*)",
      "Bash(hcom --help)",
      "Bash(uvx hcom --help)",
      "Bash(hcom -h)",
      "Bash(uvx hcom -h)",
      "Bash(hcom list:*)",
      "Bash(uvx hcom list:*)",
      "Bash(hcom events:*)",
      "Bash(uvx hcom events:*)",
      "Bash(hcom listen:*)",
      "Bash(uvx hcom listen:*)",
      "Bash(hcom relay:*)",
      "Bash(uvx hcom relay:*)",
      "Bash(hcom config:*)",
      "Bash(uvx hcom config:*)",
      "Bash(hcom transcript:*)",
      "Bash(uvx hcom transcript:*)",
      "Bash(hcom archive:*)",
      "Bash(uvx hcom archive:*)",
      "Bash(hcom bundle:*)",
      "Bash(uvx hcom bundle:*)",
      "Bash(hcom status:*)",
      "Bash(uvx hcom status:*)",
      "Bash(hcom --version)",
      "Bash(uvx hcom --version)",
      "Bash(hcom -v)",
      "Bash(uvx hcom -v)",
      "Bash(hcom --new-terminal)",
      "Bash(uvx hcom --new-terminal)"
    ]
  },
  "rules": [
    "rules/python.md"
  ]
}