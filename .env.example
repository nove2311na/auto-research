# research-pipeline workspace env (gitignored — copy to .env and fill in)
#
# No API key needed. The 7 agents are spawned via `hcom N claude --tag ...`
# which uses your existing Claude Code CLI auth (run `claude` once to log in).
#
# Only the optional Slack webhook needs config if you want pipeline-completion
# notifications.

# Optional: Slack webhook for pipeline-completion notifications.
# tools/notify.py (if you write one) silently no-ops when this is unset.
SLACK_WEBHOOK=https://hooks.slack.com/services/...

# Optional: override the hcom tag (default: research-pipeline)
HCOM_TAG=research-pipeline
