{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "agent-spec",
  "description": "Formal Draft-7 contract for an agent spec file (one per agents/<role>/). Authored from .docs/agentic/templates/agent-spec.md; consumed by tools.spec_io.",
  "type": "object",
  "required": [
    "name",
    "hcom_target",
    "folder",
    "lifecycle",
    "purpose",
    "antonio_gulli_patterns",
    "claude_code_book_chapters",
    "skills_owned",
    "tools_allowed",
    "tools_denied",
    "input_contract",
    "output_contract",
    "hard_rules",
    "reads_at_session_start",
    "writes_during_session",
    "persistence",
    "inbound_handoffs",
    "outbound_handoffs",
    "failure_modes",
    "self_verification",
    "refactor_delta"
  ],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$",
      "minLength": 1
    },
    "hcom_target": {
      "type": "string",
      "pattern": "^@research-pipeline-claude-[0-9]+$"
    },
    "folder": {
      "type": "string",
      "pattern": "^agents/[a-z0-9_-]+/?$"
    },
    "lifecycle": {
      "type": "string",
      "enum": ["per-handoff", "persistent", "singleton"]
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "antonio_gulli_patterns": {
      "type": "array",
      "items": {"type": "string", "pattern": "^Ch\\. [0-9]+ .+"},
      "minItems": 0
    },
    "claude_code_book_chapters": {
      "type": "array",
      "items": {"type": "string", "pattern": "^Ch\\. [0-9]+ .+"},
      "minItems": 0
    },
    "skills_owned": {
      "type": "array",
      "items": {"type": "string", "pattern": "^skills/[0-9]{2}_[a-z]+(\\.md)?$"},
      "minItems": 0
    },
    "tools_allowed": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["tool", "purpose", "justification"],
        "properties": {
          "tool": {"type": "string", "minLength": 1},
          "purpose": {"type": "string", "minLength": 1},
          "justification": {"type": "string", "minLength": 1}
        }
      }
    },
    "tools_denied": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 0
    },
    "input_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description", "hcom_message_pattern", "required_fields"],
      "properties": {
        "description": {"type": "string", "minLength": 1},
        "hcom_message_pattern": {"type": "string", "minLength": 1},
        "required_fields": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 0
        }
      }
    },
    "output_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["paths_written", "schema_ref", "examples"],
      "properties": {
        "paths_written": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1
        },
        "schema_ref": {
          "type": "string",
          "pattern": "^(schemas/[0-9]{2}_[a-z]+\\.json|\\(none\\))$"
        },
        "examples": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 0
        }
      }
    },
    "hard_rules": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 1
    },
    "reads_at_session_start": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 0
    },
    "writes_during_session": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 0
    },
    "persistence": {
      "type": "string",
      "minLength": 1
    },
    "inbound_handoffs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["from", "title_pattern", "description"],
        "properties": {
          "from": {"type": "string", "minLength": 1},
          "title_pattern": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1}
        }
      }
    },
    "outbound_handoffs": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["to", "title_pattern", "description"],
        "properties": {
          "to": {"type": "string", "minLength": 1},
          "title_pattern": {"type": "string", "minLength": 1},
          "description": {"type": "string", "minLength": 1}
        }
      }
    },
    "failure_modes": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "handling"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "handling": {"type": "string", "minLength": 1}
        }
      }
    },
    "self_verification": {
      "type": "array",
      "items": {"type": "string", "minLength": 1},
      "minItems": 0
    },
    "refactor_delta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "current_state", "target_state", "concrete_steps"],
      "properties": {
        "scope": {
          "type": "string",
          "enum": ["Small", "Medium", "Large"]
        },
        "current_state": {"type": "string", "minLength": 1},
        "target_state": {"type": "string", "minLength": 1},
        "concrete_steps": {
          "type": "array",
          "items": {"type": "string", "minLength": 1},
          "minItems": 1
        }
      }
    }
  }
}
