{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "04_synthesize",
  "description": "Synthesized insights and a draft summary, derived from the analysis.",
  "type": "object",
  "required": ["summary", "insights", "narrative", "diagrams", "theses"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "description": "1-3 sentence TL;DR. Will become the 'summary' field in the final report."
    },
    "insights": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["insight", "grounding"],
        "properties": {
          "insight": {"type": "string", "minLength": 1},
          "grounding": {
            "type": "string",
            "description": "Reference to a theme/gap/contradiction from 03_analyze."
          },
          "novelty": {"type": "string", "enum": ["high", "medium", "low"]}
        }
      }
    },
    "narrative": {
      "type": "string",
      "minLength": 1,
      "description": "A longer connected paragraph weaving the insights together. The formatter will polish this for the final report."
    },
    "diagrams": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "title", "code"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["flowchart", "sequence", "mindmap", "graph", "class", "state", "concept"]
          },
          "title": {"type": "string", "minLength": 1},
          "code": {
            "type": "string",
            "minLength": 1,
            "description": "Mermaid syntax, NO ```mermaid wrapper — formatter adds that"
          },
          "description": {"type": "string"}
        }
      }
    },
    "theses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["statement", "evidence", "counterarguments"],
        "properties": {
          "statement": {
            "type": "string",
            "minLength": 1,
            "description": "the synthesized position"
          },
          "evidence": {
            "type": "array",
            "items": {"type": "string"}
          },
          "counterarguments": {
            "type": "array",
            "items": {"type": "string"}
          },
          "confidence": {"type": "string", "enum": ["high", "medium", "low"]}
        }
      }
    }
  }
}
