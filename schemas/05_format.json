{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "05_format",
  "description": "Final research-report JSON. The 'output parser' schema, applied at the last stage.",
  "type": "object",
  "required": ["summary", "entities", "facts", "analysis", "insights", "references", "diagrams", "theses"],
  "properties": {
    "summary": {
      "type": "string",
      "minLength": 1,
      "description": "1-3 sentence TL;DR of the whole research output."
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "mentions"],
        "properties": {
          "name": {"type": "string"},
          "type": {"type": "string"},
          "mentions": {"type": "integer", "minimum": 0}
        }
      }
    },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim", "source"],
        "properties": {
          "claim": {"type": "string"},
          "source": {"type": "string", "description": "Quote or pointer to evidence."}
        }
      }
    },
    "analysis": {
      "type": "object",
      "properties": {
        "themes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "supporting_facts"],
            "properties": {
              "name": {"type": "string", "minLength": 1},
              "description": {"type": "string"},
              "supporting_facts": {"type": "array", "items": {"type": "string"}}
            }
          }
        },
        "gaps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["description", "what_would_fill_it"],
            "properties": {
              "description": {"type": "string", "minLength": 1},
              "what_would_fill_it": {"type": "string", "minLength": 1}
            }
          }
        },
        "contradictions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["claim_a", "claim_b", "explanation"],
            "properties": {
              "claim_a": {"type": "string", "minLength": 1},
              "claim_b": {"type": "string", "minLength": 1},
              "explanation": {"type": "string"}
            }
          }
        }
      }
    },
    "insights": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string"}
    },
    "references": {
      "type": "array",
      "items": {"type": "string"},
      "description": "URLs, document names, or pointers back to the source."
    },
    "diagrams": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "title", "code"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["flowchart", "sequence", "mindmap", "graph", "class", "state", "concept"]
          },
          "title": {"type": "string", "minLength": 1},
          "code": {
            "type": "string",
            "minLength": 1,
            "description": "Mermaid syntax, NO ```mermaid wrapper — formatter adds that"
          },
          "description": {"type": "string"}
        }
      }
    },
    "theses": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["statement", "evidence", "counterarguments"],
        "properties": {
          "statement": {
            "type": "string",
            "minLength": 1,
            "description": "the synthesized position"
          },
          "evidence": {
            "type": "array",
            "items": {"type": "string"}
          },
          "counterarguments": {
            "type": "array",
            "items": {"type": "string"}
          },
          "confidence": {"type": "string", "enum": ["high", "medium", "low"]}
        }
      }
    }
  }
}
