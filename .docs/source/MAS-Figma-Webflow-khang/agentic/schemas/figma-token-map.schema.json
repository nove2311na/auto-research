{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Figma Token Map",
  "description": "Raw Figma variable paths mapped to Client-First class names. Generated by LLM from Figma MCP get_variable_defs output.",
  "type": "object",
  "required": ["figma_file_id", "updated_at", "naming_convention", "mappings"],
  "properties": {
    "figma_file_id": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp."
    },
    "naming_convention": {
      "type": "object",
      "required": ["pattern", "categories"],
      "properties": {
        "pattern": {
          "type": "string",
          "description": "Template for CF class names, e.g. '{cf_category}-{semantic_name}'."
        },
        "categories": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "mappings": {
      "type": "object",
      "description": "Map of Figma token path → CF class name(s).",
      "additionalProperties": {
        "type": "object",
        "required": ["figma_value"],
        "properties": {
          "figma_value": {
            "type": "string",
            "description": "Raw value from Figma (hex, px, etc.)."
          },
          "cf_text_class": {"type": "string"},
          "cf_bg_class": {"type": "string"},
          "cf_border_class": {"type": "string"},
          "cf_class": {
            "type": "string",
            "description": "Single CF class for non-color tokens (spacing, font-size, etc.)."
          },
          "rem_value": {
            "type": "string",
            "description": "Converted rem value for spacing/typography tokens."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
