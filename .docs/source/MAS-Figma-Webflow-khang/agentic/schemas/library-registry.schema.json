{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Library Registry",
  "description": "Index of all per-project Client-First libraries in this repo.",
  "type": "object",
  "required": ["version", "projects"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Registry schema version."
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "webflow_site_id", "figma_file_id", "library_path"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1,
            "description": "Same as webflow_site_id; used as primary key."
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable project name."
          },
          "webflow_site_id": {
            "type": "string",
            "minLength": 1
          },
          "figma_file_id": {
            "type": "string"
          },
          "library_path": {
            "type": "string",
            "description": "Relative path from repo root to client-first-library.json."
          },
          "last_synced": {
            "type": ["string", "null"],
            "description": "ISO 8601 timestamp of last Webflow sync; null if never synced."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
