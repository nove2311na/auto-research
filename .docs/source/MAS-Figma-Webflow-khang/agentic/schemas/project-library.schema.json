{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Per-Project Client-First Library",
  "description": "Per-project class-to-CSS-property map derived from Figma variables and Client-First naming rules.",
  "type": "object",
  "required": ["project_id", "webflow_site_id", "figma_file_id", "version", "updated_at", "classes"],
  "properties": {
    "project_id": {
      "type": "string",
      "minLength": 1,
      "description": "Webflow site ID used as project identifier."
    },
    "webflow_site_id": {
      "type": "string",
      "minLength": 1
    },
    "figma_file_id": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "minLength": 1,
      "description": "Semantic version string, e.g. '1.0.0'."
    },
    "updated_at": {
      "type": "string",
      "description": "ISO 8601 timestamp of last update."
    },
    "classes": {
      "type": "object",
      "description": "Map of CF class name → class definition.",
      "additionalProperties": {
        "type": "object",
        "required": ["figma_token", "cf_category", "webflow_property", "value"],
        "properties": {
          "figma_token": {
            "type": "string",
            "minLength": 1,
            "description": "Figma variable path, e.g. 'colors/brand/primary'."
          },
          "cf_category": {
            "type": "string",
            "enum": [
              "text-color",
              "background-color",
              "border-color",
              "spacing",
              "font-size",
              "font-weight",
              "border-radius",
              "opacity"
            ]
          },
          "webflow_property": {
            "type": "string",
            "minLength": 1,
            "description": "CSS property name as used in Webflow style_tool."
          },
          "value": {
            "type": "string",
            "minLength": 1,
            "description": "CSS value string, e.g. '#FF5733' or '3rem'."
          },
          "description": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
