{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentic.local/agent_system_spec.schema.json",
  "title": "Agent System Spec",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "summary",
    "agents",
    "skills",
    "tools",
    "mcp_servers",
    "workflows",
    "memory",
    "gates",
    "scaffold_files",
    "validation_report"
  ],
  "properties": {
    "summary": {
      "type": "object"
    },
    "agents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/agent"
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/skill"
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/tool"
      }
    },
    "mcp_servers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/mcp_server"
      }
    },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/workflow"
      }
    },
    "memory": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/memory_item"
      }
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/gate"
      }
    },
    "scaffold_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/scaffold_file"
      }
    },
    "validation_report": {
      "type": "object",
      "required": ["v1_benchmark_alignment"],
      "properties": {
        "v1_benchmark_alignment": {
          "$ref": "#/$defs/v1_benchmark_alignment"
        }
      },
      "additionalProperties": true
    }
  },
  "$defs": {
    "agent": {
      "type": "object",
      "required": ["name", "role", "trigger", "allowed_tools", "forbidden_actions", "input_contract", "output_contract", "stop_conditions", "escalation"],
      "properties": {
        "name": { "type": "string" },
        "role": { "type": "string" },
        "trigger": { "type": "string" },
        "allowed_tools": { "type": "array", "items": { "type": "string" } },
        "forbidden_actions": { "type": "array", "items": { "type": "string" } },
        "input_contract": { "type": "object" },
        "output_contract": { "type": "object" },
        "stop_conditions": { "type": "array", "items": { "type": "string" } },
        "escalation": { "type": "string" }
      },
      "additionalProperties": true
    },
    "skill": {
      "type": "object",
      "required": ["name", "description", "when_to_use", "workflow", "validation"],
      "additionalProperties": true
    },
    "tool": {
      "type": "object",
      "required": ["name", "purpose", "risk_class", "approval_policy", "auth_requirements", "allowed_agents", "validation"],
      "additionalProperties": true
    },
    "mcp_server": {
      "type": "object",
      "required": ["name", "purpose", "risk_class", "approval_policy", "auth_requirements", "allowed_agents", "config_path"],
      "additionalProperties": true
    },
    "workflow": {
      "type": "object",
      "required": ["name", "trigger", "inputs", "steps", "outputs", "retry_limit", "stop_conditions", "validation_gate"],
      "additionalProperties": true
    },
    "memory_item": {
      "type": "object",
      "required": ["path", "kind", "owner", "promotion_rule"],
      "additionalProperties": true
    },
    "gate": {
      "type": "object",
      "required": ["name", "command_or_rule", "scope", "pass_condition"],
      "additionalProperties": true
    },
    "scaffold_file": {
      "type": "object",
      "required": ["path", "kind", "owner", "source_template", "write_mode", "validation"],
      "additionalProperties": true
    },
    "v1_benchmark_alignment": {
      "type": "object",
      "required": [
        "structure_profile",
        "expected_v1_validator",
        "v1_quality_target",
        "v2_seed_quality_target",
        "parity_items",
        "exceedance_items",
        "documented_skips"
      ],
      "properties": {
        "structure_profile": {
          "type": "string",
          "enum": ["minimal", "standard", "full"]
        },
        "expected_v1_validator": {
          "type": "string"
        },
        "v1_quality_target": {
          "type": "number",
          "minimum": 3.8
        },
        "v2_seed_quality_target": {
          "type": "number",
          "minimum": 4.0
        },
        "parity_items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "exceedance_items": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "documented_skips": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    }
  }
}
