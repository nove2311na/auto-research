{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentic.local/seed_input.schema.json",
  "title": "Seed Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "idea",
    "jobs_to_be_done",
    "domain",
    "target_runtime",
    "stack",
    "risk_level",
    "reference_repos",
    "required_tools",
    "constraints",
    "success_criteria"
  ],
  "properties": {
    "idea": {
      "type": "string",
      "minLength": 10
    },
    "jobs_to_be_done": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "domain": {
      "type": "string",
      "minLength": 2
    },
    "target_runtime": {
      "type": "string",
      "enum": ["claude_code", "claude_code_plus_hcom", "generic_agentic"]
    },
    "stack": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "standard", "high", "regulated"]
    },
    "reference_repos": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "required_tools": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 2
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 3
      }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 3
      }
    }
  }
}

