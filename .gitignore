# Python
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info/

# Virtual env
.venv/
worktrees/

# Generated/dev
dev/

# hcom runtime
.hcom/

# Pipeline state (regenerated on each run)
prd.json
progress.md

# Inbox / processed (input material; can be large or sensitive)
inputs/inbox/
inputs/processed/

# Pipeline outputs (regenerated per input; can be large)
outputs/

# Observability traces (regenerated per run; can be large)
observability/traces/agent_runs/*.json
observability/traces/tool_calls/*.json
observability/traces/memory_reads/*.json
observability/traces/memory_writes/*.json
observability/traces/gates/*.json
observability/traces/approvals/*.json
observability/dashboards/dashboard_*.json

# Eval scorecards (regenerated per run)
evals/scorecards/*.json

# Local env
.env

# macOS noise
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*.swo
